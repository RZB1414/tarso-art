{
  "name": "tarsoart",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5174 --strictPort",
    "worker:dev": "wrangler dev worker/index.ts --local --persist-to .wrangler/state --port 8790",
    "deploy:check": "node scripts/check-deploy-config.mjs",
    "worker:deploy": "npm run deploy:check && wrangler deploy --keep-vars",
    "d1:migrate:local": "wrangler d1 migrations apply tarsoart-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply tarsoart-db --remote",
    "hash:password": "node scripts/hash-admin-password.mjs",
    "totp:setup": "node scripts/generate-totp-secret.mjs",
    "security:smoke": "node scripts/security-smoke.mjs",
    "security:pentest": "node scripts/security-smoke.mjs --pentest"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.20.0"
  }
}
